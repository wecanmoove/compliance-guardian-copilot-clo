# App
APP_ENV=development
APP_NAME=Compliance Guardian Copilot
APP_VERSION=0.1.0
SECRET_KEY=your-secret-key-change-in-prod

# Database
DATABASE_URL=postgresql://cgc_user:cgc_password@localhost:5432/cgc_db

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI (remplacer par Claude, Gemini, etc.)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Or use Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=...
# AZURE_OPENAI_MODEL=gpt-4

# Or use Claude
# ANTHROPIC_API_KEY=...

# Vector DB
PGVECTOR_ENABLED=true
VECTOR_DIMENSION=1536

# Auth
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# S3 / File Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads
# Or S3:
# AWS_S3_BUCKET=...
# AWS_S3_REGION=us-east-1

# Logging
LOG_LEVEL=INFO

# Copilot
COPILOT_MAX_TURNS=10
COPILOT_TEMPERATURE=0.3
COPILOT_MAX_TOKENS=2000
